{
  "name": "nexus-protocol",
  "version": "0.0.1",
  "private": true,
  "description": "NEXUS Agent Economy Protocol — Stripe Connect for AI Agents",
  "author": "Simón Franco",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
