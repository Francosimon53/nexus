{
  "name": "@nexus-protocol/shared",
  "version": "0.1.0",
  "description": "Shared types, schemas, and utilities for the NEXUS Agent Economy Protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
